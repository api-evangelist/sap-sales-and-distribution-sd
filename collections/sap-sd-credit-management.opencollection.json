              {
                "name": "$select",
                "value": "",
                "type": "query"
              },
              {
                "name": "$expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns credit management data for a single business partner, including credit rating, risk class, and credit block status."
        },
        {
          "info": {
            "name": "Update a credit management account",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_CREDIT_MANAGEMENT/A_CrdtMgmtBusinessPartner(':BusinessPartner')",
