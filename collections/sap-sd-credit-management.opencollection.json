        "name": "Credit Limit",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve credit limits",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_CREDIT_MANAGEMENT/A_CrdtMgmtCreditLimit",
