            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_CREDIT_MANAGEMENT/A_CrdtMgmtCreditExposure(BusinessPartner=':BusinessPartner',CreditSegment=':CreditSegment')",
