                "name": "BusinessPartner",
                "value": "",
                "type": "path",
                "description": "Business partner number"
              },
              {
                "name": "CreditSegment",
                "value": "",
                "type": "path",
                "description": "Credit segment"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
