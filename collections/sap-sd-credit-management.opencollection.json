            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_CREDIT_MANAGEMENT/A_CrdtMgmtCreditLimit(BusinessPartner=':BusinessPartner',CreditSegment=':CreditSegment')",
