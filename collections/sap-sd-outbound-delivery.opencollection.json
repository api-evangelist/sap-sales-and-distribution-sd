            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_OUTBOUND_DELIVERY_SRV/A_OutbDeliveryHeader(':DeliveryDocument')/to_DeliveryDocumentPartner",
            "params": [
              {
                "name": "DeliveryDocument",
                "value": "",
                "type": "path",
                "description": "Delivery document number"
              },
              {
                "name": "$top",
                "value": "",
                "type": "query",
                "description": "Maximum number of records to return"
              },
              {
                "name": "$skip",
                "value": "",
                "type": "query",
                "description": "Number of records to skip"
              },
              {
                "name": "$select",
                "value": "",
                "type": "query",
                "description": "Comma-separated properties to include"
              }
            ]
